{
  "_comment": "2026-07-02: heavy code MCPs are disabled here; keeping rust-analyzer-mcp disabled avoids duplicate rust-analyzer.",
  "mcpServers": {
    "cratesio": {
      "command": "cratesio-mcp"
    }
  },
  "_disabledMcpServers": {
    "rust-analyzer-mcp": {
      "command": "rust-analyzer-mcp"
    },
    "rust-docs": {
      "command": "rust-docs-mcp"
    },
    "rust-mcp-server": {
      "command": "rust-mcp-server",
      "args": ["--workspace", "."]
    }
  }
}
